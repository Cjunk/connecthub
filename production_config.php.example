<?php
/**
 * Production configuration example for GoDaddy
 * Copy to project root as production_config.php and update values.
 */

// Environment
define('APP_ENV', 'production');
define('APP_DEBUG', false);

// URLs - update to your domain
define('BASE_URL', 'https://your-domain.com');
define('SITE_URL', BASE_URL);

// Database (GoDaddy cPanel -> MySQL Databases)
// Host often looks like: localhost
// DB name/user often prefixed: yourcpanelprefix_uhura_dbase
// For example:
//   DB_HOST = 'localhost'
//   DB_NAME = 'phnk96925bbc_uhura_dbase' or similar
//   DB_USER = 'phnk96925bbc_user'
//   DB_PASS = 'your-strong-password'

define('DB_HOST', 'localhost');
define('DB_NAME', 'uhura_dbase');
define('DB_USER', 'your_db_user');
define('DB_PASS', 'your_db_password');
define('DB_PORT', 3306);

define('DB_CHARSET', 'utf8mb4');

// Email/SMTP (optional)
